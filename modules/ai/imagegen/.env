# Image-generation stack config. AI_MODELS_ROOT matches the companion stack's NVMe mount and the
# dirs created by modules/ai/imagegen-host.nix (suzu.ai.imagegenHost).
AI_MODELS_ROOT=/home/suzu/ai-models

# Generated images land on the 12TB HDD RAID1 (mirrored + roomy), not the AI NVMe — outputs grow
# unbounded and the write is a tiny one-time PNG save with no perf penalty. Models/workflows/cache
# stay on the fast NVMe (AI_MODELS_ROOT). Dirs created by modules/ai/imagegen-host.nix.
IMAGEGEN_OUTPUT_ROOT=/home/suzu/hdd/imagegen

# NOTE: the CivitAI API token is NOT here anymore — it's managed by sops-nix and materialized at
# /run/secrets/civitai_api_token (see modules/nixos/secrets.nix). Downloads read it from there, so
# no secret lives in this git-tracked file. Browser downloads need no token at all.
